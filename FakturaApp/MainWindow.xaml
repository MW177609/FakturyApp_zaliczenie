<Window x:Class="FakturyApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Fakturujący" Height="650" Width="1100">
    <Grid>
        <TabControl x:Name="MainTabControl">

            <TabItem Header="Kontrahenci">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.5*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="dgKontrahenci" Grid.Column="0" Margin="10" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID Nabywcy" Binding="{Binding Id}" Width="80"/>
                            <DataGridTextColumn Header="Nazwa Firmy/Osoby" Binding="{Binding Nazwa}" Width="*"/>
                            <DataGridTextColumn Header="NIP" Binding="{Binding NIP}" Width="100"/>
                            <DataGridTextColumn Header="Kraj" Binding="{Binding Kraj}" Width="80"/>
                            <DataGridTextColumn Header="Adres" Binding="{Binding Adres}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Column="1" Margin="10">
                        <TextBlock Text="Dodaj nowego kontrahenta" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <TextBlock Text="Nazwa:" />
                        <TextBox x:Name="txtNazwa" Margin="0,0,0,10" />
                        <TextBlock Text="NIP:" />
                        <TextBox x:Name="txtNIP" Margin="0,0,0,10" />
                        <TextBlock Text="Kraj:" />
                        <TextBox x:Name="txtKraj" Margin="0,0,0,10" Text="Polska" />
                        <TextBlock Text="Adres:" />
                        <TextBox x:Name="txtAdres" Margin="0,0,0,15" />

                        <Button Content="Dodaj kontrahenta" Click="BtnDodajKontrahenta_Click" Padding="5" Background="#4CAF50" Foreground="White" Margin="0,0,0,20"/>

                        <Separator Margin="0,0,0,20"/>
                        <TextBlock Text="Zarządzanie" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <Button Content="Usuń wybranego z tabeli" Click="BtnUsunKontrahenta_Click" Padding="5" Background="#F44336" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Faktury">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.5*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="dgFaktury" Grid.Column="0" Margin="10" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID Nabywcy" Binding="{Binding Nabywca.Id}" Width="80"/>
                            <DataGridTextColumn Header="Nr Faktury" Binding="{Binding NumerFaktury}" Width="100"/>
                            <DataGridTextColumn Header="Data wystawienia" Binding="{Binding DataWystawienia, StringFormat=dd.MM.yyyy}" Width="120"/>
                            <DataGridTextColumn Header="Nabywca" Binding="{Binding Nabywca.Nazwa}" Width="*"/>
                            <DataGridTextColumn Header="Suma Brutto" Binding="{Binding SumaDoWyswietlenia}" Width="120"/>
                            <DataGridTextColumn Header="Typ" Binding="{Binding TypDokumentu}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Column="1" Margin="10">
                        <Button Content="Wystaw nową fakturę" Click="BtnWystawFakture_Click" Padding="10" Background="#2196F3" Foreground="White" Margin="0,0,0,10"/>
                        <Button x:Name="btnGenerujPdf" Content="Generuj PDF dla wybranej" Click="BtnGenerujPdf_Click" Padding="10" Background="#FF9800" Foreground="White" Margin="0,0,0,20"/>

                        <Separator Margin="0,0,0,20"/>
                        <Button Content="Edytuj wybraną" Click="BtnEdytujFakture_Click" Padding="10" Background="#9C27B0" Foreground="White" Margin="0,0,0,10"/>
                        <Button Content="Usuń wybraną" Click="BtnUsunFakture_Click" Padding="10" Background="#F44336" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Kreator / Edytor">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="Wybierz Nabywcę:" FontWeight="Bold"/>
                        <ComboBox x:Name="cmbKontrahenci" DisplayMemberPath="Nazwa" Margin="0,5,0,10"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1.5*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="Numer faktury:"/>
                                <TextBox x:Name="txtNumerFaktury" Text="FV "/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="5,0,5,0">
                                <TextBlock Text="Data wystawienia:"/>
                                <DatePicker x:Name="dpDataWystawienia"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="5,0,5,0">
                                <TextBlock Text="Waluta:"/>
                                <ComboBox x:Name="cmbWaluta" SelectionChanged="CmbWaluta_SelectionChanged">
                                    <ComboBoxItem Content="PLN" IsSelected="True"/>
                                    <ComboBoxItem Content="EUR"/>
                                    <ComboBoxItem Content="USD"/>
                                    <ComboBoxItem Content="GBP"/>
                                    <ComboBoxItem Content="CHF"/>
                                    <ComboBoxItem Content="CZK"/>
                                    <ComboBoxItem Content="NOK"/>
                                    <ComboBoxItem Content="SEK"/>
                                    <ComboBoxItem Content="DKK"/>
                                    <ComboBoxItem Content="AUD"/>
                                    <ComboBoxItem Content="CAD"/>
                                    <ComboBoxItem Content="HUF"/>
                                    <ComboBoxItem Content="JPY"/>
                                    <ComboBoxItem Content="TRY"/>
                                    <ComboBoxItem Content="UAH"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="5,0,5,0">
                                <TextBlock Text="Kurs na PLN:" ToolTip="Pobierany automatycznie z NBP"/>
                                <TextBox x:Name="txtKursWaluty" Text="1" IsReadOnly="True" Background="#EAEAEA"/>
                            </StackPanel>

                            <Border Grid.Column="4" Margin="5,0,0,0" Background="#FFF3E0" Padding="5">
                                <StackPanel>
                                    <CheckBox x:Name="chkKorekta" Content="Korekta" Checked="ChkKorekta_Zmieniono" Unchecked="ChkKorekta_Zmieniono" FontWeight="Bold"/>
                                    <TextBlock Text="Do faktury nr:" Margin="0,5,0,0" FontSize="11"/>
                                    <TextBox x:Name="txtKorygowanaFaktura" IsEnabled="False" ToolTip="Wpisz numer oryginalnej faktury"/>
                                    <TextBlock Text="Powód korekty:" Margin="0,5,0,0" FontSize="11"/>
                                    <TextBox x:Name="txtPowodKorekty" IsEnabled="False" ToolTip="Np. zwrot towaru, pomyłka w cenie"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <GroupBox Grid.Row="1" Header="Dodaj nową pozycję do faktury" Margin="0,5,0,10">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Vertical" Margin="5,0" Width="250">
                                <TextBlock Text="Nazwa towaru / usługi" Foreground="Gray" FontSize="10"/>
                                <TextBox x:Name="txtNazwaTowaru" ToolTip="Wpisz nazwę usługi lub towaru" Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Vertical" Margin="5,0" Width="50">
                                <TextBlock Text="Ilość" Foreground="Gray" FontSize="10" HorizontalAlignment="Center"/>
                                <TextBox x:Name="txtIloscTowaru" ToolTip="Wpisz liczbę" Margin="0,2,0,0" Text="1" TextAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Vertical" Margin="5,0" Width="100">
                                <TextBlock Text="Cena Netto" Foreground="Gray" FontSize="10"/>
                                <TextBox x:Name="txtCenaTowaruNetto" ToolTip="Cena jednostkowa bez VAT" Margin="0,2,0,0" TextAlignment="Right"/>
                            </StackPanel>
                            <StackPanel Orientation="Vertical" Margin="5,0" Width="50">
                                <TextBlock Text="VAT %" Foreground="Gray" FontSize="10" HorizontalAlignment="Center"/>
                                <TextBox x:Name="txtStawkaVat" ToolTip="Np. 23" Margin="0,2,0,0" Text="23" TextAlignment="Center"/>
                            </StackPanel>
                            <Button x:Name="btnDodajPozycje" Content="Dodaj" Margin="10,15,0,0" VerticalAlignment="Center" Padding="15,5" Click="BtnDodajPozycje_Click"/>
                        </StackPanel>
                    </GroupBox>

                    <DataGrid x:Name="dgPozycje" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,0,10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nazwa towaru/usługi" Binding="{Binding NazwaTowaruUslugi}" Width="*"/>
                            <DataGridTextColumn Header="Ilość" Binding="{Binding Ilosc}" Width="60"/>
                            <DataGridTextColumn Header="Cena Netto" Binding="{Binding CenaNetto, StringFormat=N2}" Width="100"/>
                            <DataGridTextColumn Header="VAT %" Binding="{Binding StawkaVat}" Width="60"/>
                            <DataGridTextColumn Header="Wartość Brutto" Binding="{Binding WartoscBrutto, StringFormat=N2}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="3" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="Usuń wybraną pozycję" Click="BtnUsunPozycje_Click" 
                                Padding="15,8" Background="#F44336" Foreground="White" VerticalAlignment="Center"/>

                        <TextBlock x:Name="txtSuma" Grid.Column="1" Text="Suma: 0,00" FontWeight="Bold" FontSize="16" 
                                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,20,0"/>

                        <Button Grid.Column="2" Content="Zapisz Fakturę" Click="BtnZapiszFakture_Click" 
                                Padding="20,8" Background="#4CAF50" Foreground="White" FontWeight="Bold" 
                                VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>